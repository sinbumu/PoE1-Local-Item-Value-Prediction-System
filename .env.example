POE_CLIENT_ID=your-client-id
POE_CLIENT_SECRET=your-client-secret
POE_USER_AGENT=OAuth your-app/1.0.0 (contact: you@example.com)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/poe_stash
START_NEXT_CHANGE_ID=
TARGET_LEAGUE=Mirage
POE_REALM=pc
POLL_INTERVAL_MS=10000
# Google Drive OAuth refresh-token 업로드용
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# 업로드 대상 Google Drive 폴더 ID
# 예: https://drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_ID=
# 로컬에서 압축 파일을 잠시 저장할 경로
ARCHIVE_OUTPUT_DIR=.archive/normalized
# raw_api_responses 보관 시간(시간 단위)
RAW_RETENTION_HOURS=24
# normalized_priced_items를 stale listing으로 보고 정리할 기준(last_seen=updated_at, 시간 단위)
NORMALIZED_RETENTION_HOURS=168
# 1회 아카이브 배치 최대 행 수
NORMALIZED_ARCHIVE_LIMIT=10000
# maintenance 루프 체크 주기(ms)
MAINTENANCE_POLL_INTERVAL_MS=60000
# maintenance에서 normalized archive sweep를 돌릴 간격(ms)
MAINTENANCE_ARCHIVE_INTERVAL_MS=3600000
# maintenance에서 raw cleanup를 돌릴 간격(ms)
MAINTENANCE_RAW_CLEANUP_INTERVAL_MS=86400000
# maintenance에서 환율 스냅샷 수집을 돌릴 간격(ms)
MAINTENANCE_EXCHANGE_RATE_INTERVAL_MS=900000
# 1회 maintenance archive sweep에서 처리할 최대 배치 수
MAINTENANCE_ARCHIVE_MAX_BATCHES=10
