<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.blockoxyz.poe1-maintenance</string>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/PoE1-Local-Item-Value-Prediction-System</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>npm run maintenance -- --once</string>
    </array>

    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/poe1-maintenance.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/poe1-maintenance.log</string>
  </dict>
</plist>
